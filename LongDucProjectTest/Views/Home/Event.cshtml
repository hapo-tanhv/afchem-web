@{
    ViewBag.Title = "SOLAR SCADA SYSTEM - EVENT";
    ViewBag.ButtonEvent = "active";
    ViewBag.ButtonHome = "";
    ViewBag.ButtonOverview = "";
    ViewBag.ButtonAlarm = "";
    ViewBag.ButtonReport = "";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Css/Overview.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Css/Event.css" asp-append-version="true" />
    <style>
        /* Autocomplete Premium Dark Theme */
        .ui-autocomplete {
            background: rgba(15, 23, 42, 0.95) !important;
            border: 1px solid rgba(59, 130, 246, 0.4) !important;
            border-radius: 6px !important;
            color: #e2e8f0 !important;
            max-height: 250px !important;
            overflow-y: auto !important;
            z-index: 2000 !important;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5), 0 8px 10px -6px rgba(0, 0, 0, 0.5) !important;
            backdrop-filter: blur(12px) !important;
            padding: 5px 0 !important;
        }
        .ui-menu-item {
            padding: 0 !important;
            list-style: none !important;
        }
        .ui-menu-item .ui-menu-item-wrapper {
            padding: 8px 15px !important;
            color: #cbd5e1 !important;
            transition: all 0.2s ease !important;
            border: none !important;
            background: transparent !important;
            font-size: 13px !important;
            display: block !important;
        }
        .ui-menu-item .ui-menu-item-wrapper:hover,
        .ui-menu-item .ui-menu-item-wrapper.ui-state-active {
            background: rgba(59, 130, 246, 0.25) !important;
            color: #00e5ff !important;
            border: none !important;
            cursor: pointer !important;
        }
        /* Two-Row Filter Bar Override */
        .filter-bar {
            background: #1e293b !important;
            border-radius: 8px !important;
            padding: 15px 20px !important;
            margin-bottom: 20px !important;
            display: flex !important;
            flex-direction: column !important;
            gap: 15px !important;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
            border: 1px solid rgba(255, 255, 255, 0.05) !important;
        }
        .filter-inputs {
            display: flex !important;
            align-items: center !important;
            gap: 15px !important;
            flex-wrap: wrap !important;
            width: 100% !important;
        }
        .filter-group {
            display: flex;
            flex-direction: column;
            align-items: unset !important;
            gap: 10px;
        }
        .filter-actions {
            display: flex !important;
            align-items: center !important;
            justify-content: flex-end !important;
            gap: 10px !important;
            width: 100% !important;
            border-top: 1px solid rgba(255, 255, 255, 0.05) !important;
            padding-top: 12px !important;
        }
    </style>
}

<div class="overview-dashboard">
    <!-- FILTER BAR -->
    <div class="filter-bar">
        <div class="filter-inputs">
            <div class="filter-group">
                <span class="filter-label">Chọn ngày</span>
                <input type="text" id="starttime" name="starttime" class="filter-input datepicker" value="@DateTime.Now.ToString("yyyy/MM/dd")">
            </div>
            <div class="filter-group" style="margin-left: 10px;">
                <span class="filter-label">Chọn batch</span>
                <select id="batchId" class="filter-input" style="min-width: 180px;">
                    <option value="">Đang tải...</option>
                </select>
            </div>
            <div class="filter-group" style="margin-left: 10px;">
                <span class="filter-label">Chọn mẻ</span>
                <select id="runId" class="filter-input" style="min-width: 140px;" disabled>
                    <option value="0">Không có mẻ</option>
                </select>
            </div>
            <div class="filter-group" style="margin-left: 10px; position: relative;">
                <span class="filter-label">Tìm nhanh mẻ</span>
                <input type="text" id="runSearch" class="filter-input" placeholder="Nhập tên mẻ..." style="min-width: 150px; font-size: 13px;">
            </div>
        </div>
        
        <div class="filter-actions">
            <button onclick="Submit()" class="btn-custom btn-submit"><i class="fas fa-search"></i> Tìm kiếm</button>
            @if (Session["Role"] != null && (int)Session["Role"] == (int)Hino.Getdata.Common.Role.Admin)
            {
                <button onclick="ExportExcel()" class="btn-custom btn-export"><i class="fas fa-file-excel"></i> Export Excel</button>
                <button onclick="ExportCSV()" class="btn-custom btn-export"><i class="fas fa-file-csv"></i> Export CSV</button>
            }
        </div>
    </div>

    <!-- TOP ROW: CYCLE SUMMARY + ANOMALY SUMMARY -->
    <div class="event-top-grid">
        <!-- LEFT: TỔNG KẾT CHU KỲ -->
        <div class="history-panel evt-summary-panel">
            <div class="panel-header" style="margin-bottom: 15px;">
                <h3>Tổng kết chu kỳ</h3>
            </div>
            <div class="evt-summary-content" id="cycleSummaryContainer"></div>
        </div>

        <!-- RIGHT: TỔNG HỢP BẤT THƯỜNG -->
        <div class="history-panel evt-anomaly-panel">
            <div class="panel-header" style="margin-bottom: 10px;">
                <h3>Tổng hợp bất thường</h3>
            </div>
            <div class="evt-anomaly-content" id="anomalySummaryContainer"></div>
        </div>
    </div>

    <!-- BOTTOM ROW: PHASE LOG + EVENT DETAILS -->
    <div class="event-bottom-grid">
        <!-- LEFT: NHẬT KÝ THEO GIAI ĐOẠN -->
        <div class="history-panel evt-phase-panel">
            <div class="panel-header" style="margin-bottom: 15px;">
                <h3>Nhật ký theo giai đoạn</h3>
            </div>
            <div class="table-responsive">
                <table class="batch-table evt-phase-table">
                    <thead>
                        <tr>
                            <th style="width: 30px;"></th>
                            <th class="th-process">Công đoạn</th>
                            <th>T.g bắt đầu</th>
                            <th>T.g kết thúc</th>
                            <th>Trạng thái</th>
                            <th>Thời lượng</th>
                            <th>Bất thường</th>
                        </tr>
                    </thead>
                    <tbody id="phaseLogBody"></tbody>
                </table>
            </div>
        </div>

        <!-- RIGHT: CHI TIẾT SỰ KIỆN -->
        <div class="history-panel evt-detail-panel">
            <div class="panel-header" style="margin-bottom: 15px;">
                <h3>Chi tiết sự kiện</h3>
            </div>
            <div class="evt-filter-tabs" id="eventFilterTabs"></div>
            <div class="table-responsive" style="margin-top: 15px;">
                <table class="batch-table evt-detail-table">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Công đoạn</th>
                            <th>Sự kiện</th>
                            <th>Mức độ</th>
                        </tr>
                    </thead>
                    <tbody id="eventDetailBody"></tbody>
                </table>
            </div>
            <!-- GHI CHÚ -->
            <div class="evt-note" id="eventNote"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AdminLTE-master/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/AdminLTE-master/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/JavaScript/Event/EventPage.js?v=@DateTime.Now.Ticks"></script>
    <script>
        $(document).ready(function () {
            $('.datepicker').daterangepicker({
                singleDatePicker: true,
                autoApply: true,
                locale: {
                    format: 'YYYY/MM/DD',
                    daysOfWeek: ["CN", "T2", "T3", "T4", "T5", "T6", "T7"],
                    monthNames: ["Tháng 1", "Tháng 2", "Tháng 3", "Tháng 4", "Tháng 5", "Tháng 6", "Tháng 7", "Tháng 8", "Tháng 9", "Tháng 10", "Tháng 11", "Tháng 12"],
                }
            }).on('apply.daterangepicker', function (ev, picker) {
                var formattedDate = picker.startDate.format('YYYY-MM-DD');
                EventPage.loadBatches(formattedDate, function () {
                    EventPage.loadEventData();
                });
            });

            EventPage.init();
        });

        function Submit() {
            EventPage.loadEventData();
        }

        function ExportExcel() {
            var batchId = $('#batchId').val() || "";
            var runId = $('#runId').val() || "";
            var dateVal = $('#starttime').val() || "";
            var formattedDate = dateVal.replace(/\//g, '-');
            window.location.href = "/Event/ExportEventExcel?batchId=" + batchId + "&runId=" + runId + "&starttime=" + formattedDate;
        }

        function ExportCSV() {
            var batchId = $('#batchId').val() || "";
            var runId = $('#runId').val() || "";
            var dateVal = $('#starttime').val() || "";
            var formattedDate = dateVal.replace(/\//g, '-');
            window.location.href = "/Event/ExportEventCsv?batchId=" + batchId + "&runId=" + runId + "&starttime=" + formattedDate;
        }
    </script>
}