@{
    ViewBag.Title = "SOLAR SCADA SYSTEM - ALARM";
    ViewBag.ButtonAlarm = "active";
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link href="~/Css/Overview.css" rel="stylesheet" />
    <style>
        .filter-bar {
            background: #1e293b;
            border-radius: 8px;
            padding: 15px 20px;
            margin-bottom: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .filter-inputs {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
            width: 100%;
        }
        .filter-group {
            display: flex;
            flex-direction: column;
            align-items: unset !important;
            gap: 10px;
        }
        .filter-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            width: 100%;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-top: 12px;
        }
        .filter-bar label {
            color: #a9b7cb;
            margin-bottom: 0;
            font-size: 14px;
        }
        .filter-bar input[type="date"], .filter-bar select {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(59, 130, 246, 0.25);
            color: #00e5ff;
            border-radius: 4px;
            padding: 6px 10px;
            outline: none;
        }
        .filter-label {
            color: #94a3b8;
            font-weight: 500;
            font-size: 14px;
        }
        .filter-input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(59, 130, 246, 0.25);
            color: #00e5ff;
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 14px;
            outline: none;
        }
        .filter-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 1px #3b82f6;
        }
        .btn-custom {
            background: rgba(59, 130, 246, 0.2);
            color: #00e5ff;
            border: 1px solid rgba(59, 130, 246, 0.4);
            padding: 6px 15px;
            border-radius: 4px;
            transition: all 0.3s;
            cursor: pointer;
        }
        .btn-custom:hover {
            background: rgba(59, 130, 246, 0.4);
        }
        .btn-export {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.4);
        }
        .btn-export:hover {
            background: rgba(16, 185, 129, 0.4);
        }
        .dataTables_wrapper .dataTables_length, .dataTables_wrapper .dataTables_filter, 
        .dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_processing, 
        .dataTables_wrapper .dataTables_paginate, .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            color: #a9b7cb !important;
        }
        .dataTables_wrapper .dataTables_length select, .dataTables_wrapper .dataTables_filter input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(59, 130, 246, 0.25);
            color: #00e5ff;
            border-radius: 4px;
        }
        table.dataTable tbody tr {
            background-color: transparent !important;
        }
        table.dataTable tbody tr td {
            color: #e2e8f0;
        }
        table.dataTable tbody tr.odd {
            background-color: rgba(255, 255, 255, 0.02) !important;
        }
        table.dataTable tbody tr:hover {
            background-color: rgba(59, 130, 246, 0.1) !important;
        }
        .nav-tabs {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            margin-bottom: 15px;
        }
        .nav-tabs .nav-link {
            color: #a9b7cb;
            border: none;
            border-bottom: 2px solid transparent;
            font-weight: 600;
        }
        .nav-tabs .nav-link.active {
            background-color: transparent;
            color: #00e5ff;
            border-bottom: 2px solid #00e5ff;
        }
        .nav-tabs .nav-link:hover {
            border-color: transparent;
            color: #ffffff;
        }
        .row-warning td {
            color: #f59e0b !important;
        }
        .row-resolved td {
            color: #22c55e !important;
        }
        .text-left {
            text-align: left !important;
        }
        /* Autocomplete Premium Dark Theme */
        .ui-autocomplete {
            background: rgba(15, 23, 42, 0.95) !important;
            border: 1px solid rgba(59, 130, 246, 0.4) !important;
            border-radius: 6px !important;
            color: #e2e8f0 !important;
            max-height: 250px !important;
            overflow-y: auto !important;
            z-index: 2000 !important;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5), 0 8px 10px -6px rgba(0, 0, 0, 0.5) !important;
            backdrop-filter: blur(12px) !important;
            padding: 5px 0 !important;
        }
        .ui-menu-item {
            padding: 0 !important;
            list-style: none !important;
        }
        .ui-menu-item .ui-menu-item-wrapper {
            padding: 8px 15px !important;
            color: #cbd5e1 !important;
            transition: all 0.2s ease !important;
            border: none !important;
            background: transparent !important;
            font-size: 13px !important;
            display: block !important;
        }
        .ui-menu-item .ui-menu-item-wrapper:hover,
        .ui-menu-item .ui-menu-item-wrapper.ui-state-active {
            background: rgba(59, 130, 246, 0.25) !important;
            color: #00e5ff !important;
            border: none !important;
            cursor: pointer !important;
        }
    </style>
}

<div class="overview-dashboard">
    <div class="left-panel" style="width: 100%;">
        <div class="panel-header" style="margin-bottom: 15px;">
            <h3>Bảng cảnh báo</h3>
        </div>
        
        <div class="filter-bar">
            <div class="filter-inputs">
                <div class="filter-group">
                    <span class="filter-label">Từ ngày</span>
                    <input type="text" id="starttime" name="starttime" class="filter-input datepicker" value="@DateTime.Now.ToString("yyyy/MM/dd")">
                </div>
                <div class="filter-group">
                    <span class="filter-label">Đến ngày</span>
                    <input type="text" id="endtime" name="endtime" class="filter-input datepicker" value="@DateTime.Now.ToString("yyyy/MM/dd")">
                </div>
                <div class="filter-group" style="margin-left: 10px;">
                    <span class="filter-label">Chọn batch</span>
                    <select id="batchId" class="filter-input" style="min-width: 120px;">
                        <option value="0">-- Đang tải --</option>
                    </select>
                </div>
                <div class="filter-group" style="margin-left: 10px;">
                    <span class="filter-label">Chọn mẻ (Run)</span>
                    <select id="runId" class="filter-input" style="min-width: 140px;" disabled>
                        <option value="0">Không có mẻ con</option>
                    </select>
                </div>
                <div class="filter-group" style="margin-left: 10px; position: relative;">
                    <span class="filter-label">Tìm nhanh mẻ</span>
                    <input type="text" id="runSearch" class="filter-input" placeholder="Nhập tên mẻ..." style="min-width: 150px; font-size: 13px;">
                </div>
            </div>
            
            <div class="filter-actions">
                <button onclick="reloadTables()" class="btn-custom btn-submit"><i class="fas fa-search"></i> Tìm kiếm</button>
                @if (Session["Role"] != null && (int)Session["Role"] == (int)Hino.Getdata.Common.Role.Admin)
                {
                    <button onclick="ExportExcel()" class="btn-custom btn-export"><i class="fas fa-file-excel"></i> Export Excel</button>
                    <button onclick="ExportCSV()" class="btn-custom btn-export"><i class="fas fa-file-csv"></i> Export CSV</button>
                }
            </div>
        </div>

        <div class="table-responsive">
            <table id="realtimeTable" class="batch-table" style="width:100%">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Batch</th>
                        <th>Thời gian xảy ra</th>
                        <th>Thời gian phục hồi</th>
                        <th>Mô tả</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/AdminLTE-master/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/AdminLTE-master/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script>
        var realtimeDt;
        var reportDt;
        var isInitialLoad = true;

        $(document).ready(function() {
            // Init daterangepicker
            var dpLocale = {
                format: 'YYYY/MM/DD',
                daysOfWeek: ["CN", "T2", "T3", "T4", "T5", "T6", "T7"],
                monthNames: ["Tháng 1", "Tháng 2", "Tháng 3", "Tháng 4", "Tháng 5", "Tháng 6", "Tháng 7", "Tháng 8", "Tháng 9", "Tháng 10", "Tháng 11", "Tháng 12"],
            };

            $('#starttime').daterangepicker({
                singleDatePicker: true,
                autoApply: true,
                locale: dpLocale
            }).on('apply.daterangepicker', function (ev, picker) {
                var selectedDate = picker.startDate;
                var endDrp = $('#endtime').data('daterangepicker');
                if (endDrp) {
                    endDrp.minDate = selectedDate;
                    if (endDrp.startDate.isBefore(selectedDate)) {
                        endDrp.setStartDate(selectedDate);
                        endDrp.setEndDate(selectedDate);
                        $('#endtime').val(selectedDate.format('YYYY/MM/DD'));
                    }
                }
                setTimeout(function() {
                    loadBatchesRange();
                }, 50);
            });

            $('#endtime').daterangepicker({
                singleDatePicker: true,
                autoApply: true,
                locale: dpLocale
            }).on('apply.daterangepicker', function (ev, picker) {
                var selectedDate = picker.startDate;
                var startDrp = $('#starttime').data('daterangepicker');
                if (startDrp) {
                    startDrp.maxDate = selectedDate;
                    if (startDrp.startDate.isAfter(selectedDate)) {
                        startDrp.setStartDate(selectedDate);
                        startDrp.setEndDate(selectedDate);
                        $('#starttime').val(selectedDate.format('YYYY/MM/DD'));
                    }
                }
                setTimeout(function() {
                    loadBatchesRange();
                }, 50);
            });

            // Handle manual keyboard input focusout validation
            $('#starttime').on('focusout', function () {
                var startVal = $(this).val() || "";
                var endVal = $('#endtime').val() || "";
                var startM = moment(startVal, 'YYYY/MM/DD', true);
                var endM = moment(endVal, 'YYYY/MM/DD', true);
                
                if (startM.isValid() && endM.isValid()) {
                    if (startM.isAfter(endM)) {
                        $('#endtime').val(startVal);
                        var endDrp = $('#endtime').data('daterangepicker');
                        if (endDrp) {
                            endDrp.setStartDate(startM);
                            endDrp.setEndDate(startM);
                        }
                    }
                    var endDrp = $('#endtime').data('daterangepicker');
                    if (endDrp) {
                        endDrp.minDate = startM;
                    }
                    var startDrp = $(this).data('daterangepicker');
                    if (startDrp) {
                        startDrp.setStartDate(startM);
                        startDrp.setEndDate(startM);
                    }
                    loadBatchesRange();
                }
            });

            $('#endtime').on('focusout', function () {
                var startVal = $('#starttime').val() || "";
                var endVal = $(this).val() || "";
                var startM = moment(startVal, 'YYYY/MM/DD', true);
                var endM = moment(endVal, 'YYYY/MM/DD', true);
                
                if (startM.isValid() && endM.isValid()) {
                    if (startM.isAfter(endM)) {
                        $('#starttime').val(endVal);
                        var startDrp = $('#starttime').data('daterangepicker');
                        if (startDrp) {
                            startDrp.setStartDate(endM);
                            startDrp.setEndDate(endM);
                        }
                    }
                    var startDrp = $('#starttime').data('daterangepicker');
                    if (startDrp) {
                        startDrp.maxDate = endM;
                    }
                    var endDrp = $(this).data('daterangepicker');
                    if (endDrp) {
                        endDrp.setStartDate(endM);
                        endDrp.setEndDate(endM);
                    }
                    loadBatchesRange();
                }
            });

            // Bind cascading batchId changes
            $('#batchId').on('change', function () {
                $('#runSearch').val('');
                loadRuns($(this).val());
            });

            $('#runId').on('change', function () {
                $('#runSearch').val('');
            });

            // Init Autocomplete Search
            $("#runSearch").autocomplete({
                source: function (request, response) {
                    $.ajax({
                        url: "/Overview/SearchRuns",
                        type: "GET",
                        data: { query: request.term },
                        success: function (data) {
                            response($.map(data, function (item) {
                                return {
                                    label: item.label + " (" + item.batch_name + ")",
                                    value: item.label,
                                    id: item.value,
                                    batch_id: item.batch_id,
                                    batch_name: item.batch_name,
                                    batch_start: item.batch_start,
                                    batch_end: item.batch_end
                                };
                            }));
                        }
                    });
                },
                minLength: 1,
                select: function (event, ui) {
                    var item = ui.item;
                    if (item) {
                        if (item.batch_start && item.batch_end) {
                            $('#starttime').val(item.batch_start);
                            $('#endtime').val(item.batch_end);

                            var startDrp = $('#starttime').data('daterangepicker');
                            if (startDrp) {
                                startDrp.setStartDate(item.batch_start);
                                startDrp.setEndDate(item.batch_start);
                            }
                            var endDrp = $('#endtime').data('daterangepicker');
                            if (endDrp) {
                                endDrp.setStartDate(item.batch_end);
                                endDrp.setEndDate(item.batch_end);
                            }
                        }

                        loadBatchesRange(function () {
                            $('#batchId').val(item.batch_id);
                            loadRuns(item.batch_id, function () {
                                $('#runId').val(item.id);
                                reloadTables();
                            });
                        });
                    }
                }
            });

            // Init DataTable with live data
            realtimeDt = initDataTable('#realtimeTable', '/Alarm/GetAlarmsData');
        });

        function loadBatchesRange(callback) {
            var starttime = $('#starttime').val() || "";
            var endtime = $('#endtime').val() || "";
            var startFormatted = starttime.replace(/\//g, '-');
            var endFormatted = endtime.replace(/\//g, '-');

            $.ajax({
                url: '/Alarm/GetBatches',
                type: 'GET',
                data: { starttime: startFormatted, endtime: endFormatted },
                dataType: 'json',
                success: function (data) {
                    var select = $('#batchId');
                    if (select.length) {
                        select.empty();
                        select.append('<option value="0">-- Tất cả --</option>');
                        if (data && data.length > 0) {
                            data.forEach(function (item) {
                                select.append('<option value="' + item.id + '">' + item.name + '</option>');
                            });
                        }
                    }
                    loadRuns(select.val(), function () {
                        if (typeof callback === 'function') {
                            callback();
                        }
                    });
                },
                error: function (xhr, status, error) {
                    console.error('Failed to load batches:', error);
                    loadRuns("0", function () {
                        if (typeof callback === 'function') {
                            callback();
                        }
                    });
                }
            });
        }

        function loadRuns(batchId, callback) {
            var select = $('#runId');
            if (batchId === "0" || batchId === "") {
                select.empty();
                select.append('<option value="0">-- Tất cả mẻ --</option>');
                select.prop('disabled', true);
                if (typeof callback === 'function') callback();
                return;
            }

            $.ajax({
                url: '/Overview/GetRuns',
                type: 'GET',
                data: { batch_id: batchId },
                dataType: 'json',
                success: function (data) {
                    select.empty();
                    if (data && data.length > 0) {
                        select.append('<option value="0">-- Tất cả mẻ --</option>');
                        data.forEach(function (item) {
                            var statusLabel = item.status === 'Active' ? ' (Active)' : '';
                            select.append('<option value="' + item.id + '">' + item.name + statusLabel + '</option>');
                        });
                        select.prop('disabled', false);
                    } else {
                        select.append('<option value="0">Không có mẻ con</option>');
                        select.prop('disabled', true);
                    }
                    if (typeof callback === 'function') {
                        callback();
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Failed to load runs:', error);
                    select.empty();
                    select.append('<option value="0">Lỗi tải dữ liệu</option>');
                    select.prop('disabled', true);
                    if (typeof callback === 'function') {
                        callback();
                    }
                }
            });
        }

        function initDataTable(selector, url) {
            return $(selector).DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": url,
                    "type": "POST",
                    "data": function (d) {
                        d.starttime = $('#starttime').val() + " 00:00:00";
                        d.endtime = $('#endtime').val() + " 23:59:59";
                        d.batchId = $('#batchId').val();
                        d.runId = $('#runId').val() || "0";
                        d.isInitialLoad = isInitialLoad;
                    }
                },
                "createdRow": function(row, data, dataIndex) {
                    if (data.Status === 'Cảnh báo') {
                        $(row).addClass('row-warning');
                    } else if (data.Status === 'Đã khôi phục') {
                        $(row).addClass('row-resolved');
                    }
                },
                "columns": [
                    { "data": null, "render": function (data, type, row, meta) {
                        return meta.settings._iDisplayStart + meta.row + 1;
                    }},
                    { "data": "BatchId" },
                    { "data": "OccurrenceTime" },
                    { "data": "RestoreTime" },
                    { "data": "Description", "className": "text-left" },
                    { "data": "Status" },
                ],
                "ordering": false, // Disabled sorting to match Event and Report pages
                "pageLength": 10,
                "lengthMenu": [10, 25, 50, 100],
                "language": {
                    "search": "Tìm kiếm:",
                    "lengthMenu": "Hiển thị _MENU_ bản ghi",
                    "info": "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                    "infoEmpty": "Hiển thị 0 đến 0 của 0 bản ghi",
                    "infoFiltered": "(lọc từ _MAX_ bản ghi)",
                    "paginate": {
                        "first": "Đầu",
                        "last": "Cuối",
                        "next": "Sau",
                        "previous": "Trước"
                    }
                }
            }).on('xhr.dt', function (e, settings, json, xhr) {
                if (isInitialLoad && json && json.resolvedBatchId > 0) {
                    var startVal = json.batchDateStart;
                    var endVal = json.batchDateEnd;
                    $('#starttime').val(startVal);
                    $('#endtime').val(endVal);

                    var drpStart = $('#starttime').data('daterangepicker');
                    if (drpStart) {
                        drpStart.setStartDate(startVal);
                        drpStart.setEndDate(startVal);
                    }
                    var drpEnd = $('#endtime').data('daterangepicker');
                    if (drpEnd) {
                        drpEnd.setStartDate(endVal);
                        drpEnd.setEndDate(endVal);
                    }

                    loadBatchesRange(function () {
                        $('#batchId').val(json.resolvedBatchId);
                        loadRuns(json.resolvedBatchId, function () {
                            if (json.resolvedRunId > 0) {
                                $('#runId').val(json.resolvedRunId);
                            }
                        });
                    });
                    isInitialLoad = false;
                }
            });
        }

        function reloadTables() {
            if (realtimeDt) {
                realtimeDt.ajax.reload();
            }
        }

        function ExportExcel() {
            var starttime = $('#starttime').val() + " 00:00:00";
            var endtime = $('#endtime').val() + " 23:59:59";
            var batchId = $('#batchId').val();
            var runId = $('#runId').val() || "0";
            var searchValue = realtimeDt ? realtimeDt.search() : "";

            var url = "/Alarm/ExportAlarmsExcel?";
            var params = new URLSearchParams({
                starttime: starttime,
                endtime: endtime,
                batchId: batchId,
                runId: runId,
                searchValue: searchValue
            });
            window.location = url + params;
        }

        function ExportCSV() {
            var starttime = $('#starttime').val() + " 00:00:00";
            var endtime = $('#endtime').val() + " 23:59:59";
            var batchId = $('#batchId').val();
            var runId = $('#runId').val() || "0";
            var searchValue = realtimeDt ? realtimeDt.search() : "";

            var url = "/Alarm/ExportAlarmsCsv?";
            var params = new URLSearchParams({
                starttime: starttime,
                endtime: endtime,
                batchId: batchId,
                runId: runId,
                searchValue: searchValue
            });
            window.location = url + params;
        }
    </script>
}
