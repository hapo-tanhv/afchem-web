                            <div class="param-card-value">885 <small>s</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>885 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-orange"><i class="fas fa-stopwatch"></i></div>
