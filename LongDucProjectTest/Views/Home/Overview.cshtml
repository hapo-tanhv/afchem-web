<!-- Main content -->
<div class="overview-dashboard">
    <!-- TRẠNG THÁI QUY TRÌNH -->
    <div class="process-status-panel">
        <div class="panel-header">
            <h3>Trạng thái quy trình</h3>
        </div>
        <div class="process-timeline-container">
            <ul class="process-steps" id="processTimeline">
                <li class="step" data-step="1">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">1</div>
                    <div class="step-name">Cấp liệu</div>
                </li>
                <li class="step" data-step="2">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">2</div>
                    <div class="step-name">Trộn 1</div>
                </li>
                <li class="step" data-step="3">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">3</div>
                    <div class="step-name">Xả đáy</div>
                </li>
                <li class="step" data-step="4">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">4</div>
                    <div class="step-name">Rung xả đáy</div>
                </li>
                <li class="step" data-step="5">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">5</div>
                    <div class="step-name">Hút xả đáy</div>
                </li>
                <li class="step" data-step="6">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">6</div>
                    <div class="step-name">Trộn 2</div>
                </li>
                <li class="step" data-step="7">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">7</div>
                    <div class="step-name">Xả hàng</div>
                </li>
                <li class="step" data-step="8">
                    <div class="step-icon"></div>
                    <div class="step-label">8</div>
                    <div class="step-name">Rung xả hàng</div>
                </li>
            </ul>
            <div class="step-stats">
                <div class="stat-box">
                    <div class="stat-title">Bước hiện tại</div>
                    <div class="stat-val text-cyan" id="statCurrentStep">- / -</div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Thời gian chuẩn</div>
                    <div class="stat-val"><span id="statStandardTime">1800</span> <small>s</small></div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Thời gian đã chạy</div>
                    <div class="stat-val text-cyan"><span id="statElapsedTime">0</span> <small>s</small></div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Thời gian còn lại</div>
                    <div class="stat-val text-cyan"><span id="statRemainingTime">1800</span> <small>s</small></div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Tiến độ bước</div>
                    <div class="stat-val text-cyan" id="statProgressPercent">0%</div>
                    <div class="progress-bar-small">
                        <div class="progress-fill" id="statProgressFill" style="width: 0%;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- MAIN CONTENT GRID -->
    <div class="overview-main-content">
        <!-- CENTER: SƠ ĐỒ THIẾT BỊ -->
        <div class="center-panel">
            <div class="panel-header">
                <h3>SƠ ĐỒ BỒN TRỘN</h3>
            </div>
            <div class="tank-diagram-container">
                <!-- Left Column -->
                <div class="tank-side-col left-col">
                    <div class="param-card-side">
                        <div class="param-card-icon icon-blue"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian cấp liệu</div>
                            <div class="param-card-value"><span id="feedingTime">1426</span> <small>s</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>1426 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-cyan"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian trộn 1</div>
                            <div class="param-card-value"><span id="mix1Time">885</span> <small>s</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>885 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-orange"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian xả đáy</div>
                            <div class="param-card-value">
                                <span id="bottomDischargeTime">16</span> <small>s</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>496 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-purple"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian rung xả đáy</div>
                            <div class="param-card-value">
                                <span id="bottomDischargeVibrationTime">16</span>
                                <small>s</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>16 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-purple"><i class="fas fa-tachometer-alt"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Áp suất đường ống</div>
                            <div class="param-card-value">
                                <span id="TankDiagramPressure">2.50</span> <small>bar</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>2.50 bar</span></div>
                        </div>
                    </div>
                </div>
                <!-- Center Tank -->
                <div class="tank-center-wrapper">
                    <img src="~/Image/sodobontron2.jpeg" alt="Sơ đồ bồn trộn" class="tank-img" />
                    <!-- Equipment Labels -->
                    <div class="eq-label eq-pump">Bơm cấp liệu</div>
                    <div class="eq-label eq-mixer">Máy trộn</div>
                    <div class="eq-label eq-valve">Van xả đáy</div>
                    <!-- Sensor Overlays on Tank -->
                    <div class="tank-temp-card top-temp">
                        <div class="param-card-icon icon-red"><i class="fas fa-thermometer-half"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Nhiệt độ<br />bồn trộn trên</div>
                            <div class="param-card-value">
                                <span id="TankDiagramTempTop">35.2</span> <small>°C</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>35.0 °C</span></div>
                        </div>
                    </div>
                    <div class="tank-temp-card mid-temp">
                        <div class="param-card-icon icon-orange"><i class="fas fa-thermometer-half"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Nhiệt độ<br />bồn trộn giữa</div>
                            <div class="param-card-value"><span id="TankDiagramTemp">32.8</span> <small>°C</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>35.0 °C</span></div>
                        </div>
                    </div>
                    <div class="tank-temp-card bot-temp">
                        <div class="param-card-icon icon-blue"><i class="fas fa-thermometer-half"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Nhiệt độ<br />bồn trộn dưới</div>
                            <div class="param-card-value">
                                <span id="TankDiagramTempBot">30.1</span> <small>°C</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>35.0 °C</span></div>
                        </div>
                    </div>
                </div>
                <!-- Right Column -->
                <div class="tank-side-col right-col">
                    <div class="param-card-side">
                        <div class="param-card-icon icon-cyan"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian hút xả đáy</div>
                            <div class="param-card-value">
                                <span id="bottomSuctionDischargeTime">16</span>
                                <small>s</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>586 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-green"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian trộn 2</div>
                            <div class="param-card-value"><span id="mix2Time">4</span> <small>s</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>1174 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-green"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian xả hàng</div>
                            <div class="param-card-value"><span id="clearanceSaleTime">2</span> <small>s</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>1142 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-purple"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian rung xả hàng</div>
                            <div class="param-card-value">
                                <span id="vibrationDischargeTime">3</span> <small>s</small>
                            </div>
                            <div class="param-card-std">Tiêu chuẩn: <span>93 <small>s</small></span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- RIGHT PANELS COLUMN -->
        <div class="right-panels-col d-flex flex-column" style="gap: 20px;">
            <!-- THÔNG SỐ MÔI TRƯỜNG -->
            <div class="env-params-panel history-panel">
                <div class="panel-header">
                    <h3>THÔNG SỐ MÔI TRƯỜNG</h3>
                </div>
                <div class="env-params-content mt-3">
                    <div class="param-card-side mb-3" style="width: 100%;">
                        <div class="param-card-icon icon-cyan"><i class="fas fa-thermometer-half"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Nhiệt độ môi trường</div>
                            <div class="param-card-value"><span id="AmbientTemp">25.5</span> <small>°C</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>≤ 30 °C</span></div>
                        </div>
                    </div>
                    <div class="param-card-side mb-3" style="width: 100%;">
                        <div class="param-card-icon icon-blue"><i class="fas fa-tint"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Độ ẩm môi trường</div>
                            <div class="param-card-value"><span id="Humidity">60.2</span> <small>%</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>30-70 %</span></div>
                        </div>
                    </div>
                    <div class="param-card-side mb-3" style="width: 100%;">
                        <div class="param-card-icon icon-purple"><i class="fas fa-wind"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Chỉ số bụi</div>
                            <div class="param-card-value"><span id="PM25">18</span> <small>µg/m³</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>≤ 50 µg/m³</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- TỔNG QUAN MẺ -->
            <div class="batch-overview-panel history-panel">
                <div class="panel-header">
                    <h3>TỔNG QUAN BATCH</h3>
                </div>
                <div class="batch-info-content mt-3">
                    <div class="info-row border-bottom-subtle">
                        <span class="info-label">Số batch</span>
                        <span class="info-value text-white font-weight-bold" id="batchNumberInfo">-</span>
                    </div>
                    <div class="info-row border-bottom-subtle">
                        <span class="info-label">Sản phẩm</span>
                        <span class="info-value text-white font-weight-bold">Jelly Powder JP-01</span>
                    </div>
                    <div class="info-row border-bottom-subtle">
                        <span class="info-label">Sản lượng kế hoạch</span>
                        <span class="info-value text-white font-weight-bold">2.000 KG</span>
                    </div>
                    <div class="info-row border-bottom-subtle" style="margin-bottom: 10px;">
                        <span class="info-label">Sản lượng đã SX</span>
                        <span class="info-value text-white font-weight-bold">1.000 KG (50%)</span>
                    </div>
                    <div class="info-row border-bottom-subtle">
                        <span class="info-label">Thời gian bắt đầu mẻ</span>
                        <span class="info-value text-white font-weight-bold" id="batchStartTimeInfo">-</span>
                    </div>
                    <div class="info-row border-bottom-subtle">
                        <span class="info-label">Thời gian dự kiến kết thúc</span>
                        <span class="info-value text-white font-weight-bold">15:33:00</span>
                    </div>
                    <div class="info-row border-bottom-subtle">
                        <span class="info-label">Thời gian còn lại mẻ</span>
                        <span class="info-value text-white font-weight-bold">1h 20m 35s</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- BOTTOM GRID -->
    <div class="overview-bottom">
        <div style="display: grid; grid-template-columns: 1fr 350px; gap: 20px; margin-bottom: 24px;">
            <div class="history-panel main-chart-box">
                <div class="panel-header">
                    <span class="header-accent" style="background: #3b82f6;"></span>
                    <h3>Thống kê số liệu</h3>
                </div>
                <div class="gauge-container">
                    <div id="container-speed" class="gauge-item"></div>
                    <div id="container-temp" class="gauge-item"></div>
                    <div id="container-pressure" class="gauge-item"></div>
                </div>
                <div class="main-line-chart">
                    <div id="container_line" style="height: 350px;"></div>
                </div>
            </div>
            <!-- ALARM / CẢNH BÁO PANEL -->
            <div class="history-panel alarm-panel" style="display: flex; flex-direction: column;">
                <div class="panel-header"
                     style="display: flex; justify-content: space-between; align-items: center; border-bottom: none; margin-bottom: 0;">
                    <div style="display: flex; align-items: center;">
                        <span class="header-accent" style="background: #f59e0b;"></span>
                        <h3 style="margin-bottom: 0;">ALARM / CẢNH BÁO</h3>
                    </div>
                    <a href="/Home/Alarm" style="color: #3b82f6; font-size: 13px; text-decoration: none;">
                        Xem tất cả
                        &rarr;
                    </a>
                </div>
                <div class="alarm-list" id="alarmListContainer"
                     style="margin-top: 15px; display: flex; flex-direction: column; gap: 15px; overflow-y: auto; padding-right: 5px;">
                </div>
            </div>
        </div>
        <!-- LỊCH SỬ CÁC BƯỚC -->
        <div class="history-panel">
            <div class="panel-header">
                <h3>Thống kê mẻ hiện tại</h3>
            </div>
            <div class="table-responsive">
                <table class="batch-table">
                    <thead>
                        <tr>
                            <th class="th-process">Công đoạn</th>
                            <th class="th-standard">TC cài đặt</th>
                            <th class="th-start">T.g bắt đầu</th>
                            <th class="th-end">T.g kết thúc</th>
                            <th class="th-duration">Thời gian</th>
                            <th class="th-temp">NĐ bồn trên</th>
                            <th class="th-temp">NĐ bồn giữa</th>
                            <th class="th-temp">NĐ bồn dưới</th>
                            <th class="th-status">Trạng thái</th>
                            <th class="th-alerts" colspan="3">Cảnh báo</th>
                        </tr>
                    </thead>
                    <tbody id="batchTableBody">
                    </tbody>
                </table>
            </div>
        </div>
        <!-- NEW BOTTOM ROW: DAILY BATCHES & BOM -->
        <div class="bottom-tables-grid"
             style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
            <!-- LEFT: TỔNG SỐ BATCH SẢN XUẤT TRONG NGÀY -->
            <div class="bom-panel">
                <div class="panel-header">
                    <span class="header-accent" style="background: #00e5ff;"></span>
                    <h3 style="text-transform: uppercase;">Tổng số batch sản xuất trong ngày</h3>
                </div>
                <div class="table-responsive">
                    <table class="batch-table daily-batches-table" style="width: 100%; text-align: center;">
                        <thead>
                            <tr>
                                <th style="text-align: left; padding-left: 20px;">Batch</th>
                                <th style="text-align: center;">Khối lượng</th>
                                <th style="text-align: center;">Thời gian sản xuất</th>
                                <th style="text-align: center;">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody id="dailyBatchesBody">
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- RIGHT: BOM SẢN XUẤT -->
            <div class="bom-panel">
                <div class="panel-header">
                    <span class="header-accent"></span>
                    <h3>BOM sản xuất</h3>
                </div>
                <table class="bom-table">
                    <thead>
                        <tr>
                            <th class="th-code">Tên NVL</th>
                            <th class="th-name">Tỉ lệ</th>
                            <th class="th-ratio">Tổng xuất</th>
                            <th class="th-unit">ĐVT</th>
                            <th class="th-lot">LOT NVL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="td-code">AF-01</td>
                            <td class="td-name">153</td>
                            <td class="td-ratio">600</td>
                            <td class="td-unit">kg</td>
                            <td class="td-lot">20251222TRF</td>
                        </tr>
                        <tr>
                            <td class="td-code">AF-24</td>
                            <td class="td-name">140</td>
                            <td class="td-ratio">560</td>
                            <td class="td-unit">kg</td>
                            <td class="td-lot">20260306TA</td>
                        </tr>
                        <tr>
                            <td class="td-code">AF-30</td>
                            <td class="td-name">65</td>
                            <td class="td-ratio">260</td>
                            <td class="td-unit">kg</td>
                            <td class="td-lot">8820100105</td>
                        </tr>
                        <tr>
                            <td class="td-code">AF-39</td>
                            <td class="td-name">13</td>
