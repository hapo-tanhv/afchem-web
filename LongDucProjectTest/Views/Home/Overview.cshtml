<!-- Main content -->
<div class="overview-dashboard">
    <!-- TRẠNG THÁI QUY TRÌNH -->
    <div class="process-status-panel">
        <div class="panel-header">
            <h3>Trạng thái quy trình</h3>
        </div>
        <div class="process-timeline-container">
            <ul class="process-steps">
                <li class="step completed">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">1</div>
                    <div class="step-name">Cấp liệu</div>
                </li>
                <li class="step completed">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">2</div>
                    <div class="step-name">Hút xả đáy</div>
                </li>
                <li class="step completed">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">3</div>
                    <div class="step-name">Trộn 1</div>
                </li>
                <li class="step completed">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">4</div>
                    <div class="step-name">Xả đáy</div>
                </li>
                <li class="step completed">
                    <div class="step-icon"><i class="fas fa-check"></i></div>
                    <div class="step-label">5</div>
                    <div class="step-name">Rung xả đáy</div>
                </li>
                <li class="step active">
                    <div class="step-icon"></div>
                    <div class="step-label">6</div>
                    <div class="step-name">Trộn 2</div>
                </li>
                <li class="step pending">
                    <div class="step-icon"></div>
                    <div class="step-label">7</div>
                    <div class="step-name">Xả hàng</div>
                </li>
                <li class="step pending">
                    <div class="step-icon"></div>
                    <div class="step-label">8</div>
                    <div class="step-name">Rung xả hàng</div>
                </li>
            </ul>
            <div class="step-stats">
                <div class="stat-box">
                    <div class="stat-title">Bước hiện tại</div>
                    <div class="stat-val text-cyan">6 / 8</div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Thời gian chuẩn</div>
                    <div class="stat-val">1.200 <small>s</small></div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Thời gian đã chạy</div>
                    <div class="stat-val">780 <small>s</small></div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Thời gian còn lại</div>
                    <div class="stat-val">420 <small>s</small></div>
                </div>
                <div class="stat-box">
                    <div class="stat-title">Tiến độ bước</div>
                    <div class="stat-val text-cyan">75%</div>
                    <div class="progress-bar-small"><div class="progress-fill" style="width: 75%;"></div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT GRID -->
    <div class="overview-main-content">


        <!-- CENTER: SƠ ĐỒ THIẾT BỊ -->
        <div class="center-panel">
            <div class="panel-header">
                <h3>SƠ ĐỒ BỒN TRỘN</h3>
            </div>
            <div class="tank-diagram-container">
                <img src="~/Image/sodobontron.jfif" alt="Sơ đồ bồn trộn" class="tank-img" />
                
                <!-- Sensor Overlays -->
                <div class="sensor-overlay sensor-temp">
                    <div class="sensor-label">Nhiệt độ bồn</div>
                    <div class="sensor-val"><span id="TankDiagramTemp">23.9</span><small>°C</small></div>
                </div>
                
                <div class="sensor-overlay sensor-pressure">
                    <div class="sensor-label">Áp suất bồn</div>
                    <div class="sensor-val"><span id="TankDiagramPressure">0.60</span><small>bar</small></div>
                </div>
                
                <div class="sensor-overlay sensor-level">
                    <div class="sensor-label">Mực chất lỏng</div>
                    <div class="sensor-val"><span id="TankDiagramLevel">2.0</span><small>m (67%)</small></div>
                </div>
            </div>
        </div>

        <!-- TỔNG QUAN MẺ -->
        <div class="batch-overview-panel">
            <div class="panel-header">
                <h3>TỔNG QUAN MẺ</h3>
            </div>
            <div class="batch-info-content mt-3">
                <div class="info-row border-bottom-subtle">
                    <span class="info-label">Mẻ số</span>
                    <span class="info-value text-white font-weight-bold">2</span>
                </div>
                <div class="info-row border-bottom-subtle">
                    <span class="info-label">Sản phẩm</span>
                    <span class="info-value text-white font-weight-bold">Jelly Powder JP-01</span>
                </div>
                <div class="info-row border-bottom-subtle">
                    <span class="info-label">Sản lượng kế hoạch</span>
                    <span class="info-value text-white font-weight-bold">2.000 KG</span>
                </div>
                <div class="info-row border-bottom-subtle" style="margin-bottom: 10px;">
                    <span class="info-label">Sản lượng đã SX</span>
                    <span class="info-value text-white font-weight-bold">1.000 KG (50%)</span>
                </div>
                
                <div class="info-row border-bottom-subtle">
                    <span class="info-label">Thời gian bắt đầu mẻ</span>
                    <span class="info-value text-white font-weight-bold">14:02:10</span>
                </div>
                <div class="info-row border-bottom-subtle">
                    <span class="info-label">Thời gian dự kiến kết thúc</span>
                    <span class="info-value text-white font-weight-bold">15:33:00</span>
                </div>
                <div class="info-row border-bottom-subtle">
                    <span class="info-label">Thời gian còn lại mẻ</span>
                    <span class="info-value text-white font-weight-bold">1h 20m 35s</span>
                </div>
            </div>
        </div>
    </div>

