                    <div class="param-card-side">
                        <div class="param-card-icon icon-blue"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
                            <div class="param-card-title">Thời gian cấp liệu</div>
                            <div class="param-card-value">1426 <small>s</small></div>
                            <div class="param-card-std">Tiêu chuẩn: <span>1426 <small>s</small></span></div>
                        </div>
                    </div>
                    <div class="param-card-side">
                        <div class="param-card-icon icon-cyan"><i class="fas fa-stopwatch"></i></div>
                        <div class="param-card-info">
