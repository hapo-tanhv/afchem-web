
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SOL Solar SCADA</title>

    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/fontawesome-free/css/all.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

    <!-- Tempusdominus Bootstrap 4 -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
    <!-- iCheck -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    <!-- JQVMap -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/jqvmap/jqvmap.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/AdminLTE-master/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="~/AdminLTE-master/dist/css/adminlte.css">
    <!-- overlayScrollbars -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
    <!-- Daterange picker -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/daterangepicker/daterangepicker.css">
    <!-- summernote -->
    <link rel="stylesheet" href="~/AdminLTE-master/plugins/summernote/summernote-bs4.min.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <style>
        /* ==================================================================
           1. LAYOUT TỔNG THỂ
           ================================================================== */
        body { background-color: #0a0a0a !important; font-family: 'Source Sans Pro', sans-serif; }

        .main-header {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            background-color: #0f172a !important;
            border-bottom: 1px solid rgba(255,255,255,0.1) !important;
            height: 65px;
            padding: 0 20px !important;
            margin-left: 0 !important;
            position: sticky;
            top: 0;
            z-index: 1035 !important;
        }

        /* ==================================================================
           2. BRANDING (BÊN TRÁI)
           ================================================================== */
        .header-left-group { display: flex; align-items: center; gap: 15px; }
        .brand-wrapper { display: flex !important; align-items: center !important; gap: 12px; }
        .brand-text-content { display: flex !important; flex-direction: column !important; line-height: 1.1 !important; }
        .brand-text-content .main-title { color: #ffffff !important; font-weight: 700; font-size: 16px; letter-spacing: 0.5px; margin: 0 !important; }
        .brand-text-content .sub-title { color: #94a3b8 !important; font-size: 10px; text-transform: uppercase; margin: 0 !important; }

        /* ==================================================================
           3. KHỐI TIỆN ÍCH (BÊN PHẢI)
           ================================================================== */
        .header-right-group { display: flex; align-items: center; gap: 30px; }

        /* PLC Status - Dạng Card như ảnh 2 */
        .plc-status-card {
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(15, 23, 42, 0.5);
            border-radius: 8px;
            padding: 5px 15px;
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 140px;
        }
        .status-indicator { display: flex; flex-direction: column; }
        .status-label { color: #94a3b8; font-size: 10px; text-transform: uppercase; font-weight: 600; margin-bottom: -2px; }
        .status-text { color: #22c55e; font-size: 13px; font-weight: 700; }
        .dot-online { width: 12px; height: 12px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 10px #22c55e; animation: pulse 2s infinite; }

        /* Realtime Clock - Chia 2 dòng */
        .clock-wrapper { display: flex; align-items: center; gap: 12px; color: #e2e8f0; }
        .clock-icon { font-size: 20px; color: #94a3b8; }
        .clock-data { display: flex; flex-direction: column; line-height: 1.1; }
        .clock-time { font-weight: 700; font-size: 14px; color: #ffffff; }
        .clock-date { font-size: 11px; color: #64748b; }

        /* Notification */
        .notification-btn { position: relative; color: #94a3b8; font-size: 20px; transition: 0.3s; }
        .notification-btn:hover { color: #ffffff; }
        .badge-count {
            position: absolute; top: -5px; right: -5px; background: #ef4444;
            color: white; font-size: 10px; padding: 1px 5px; border-radius: 50%;
            border: 2px solid #0f172a;
        }

        /* User Profile */
        .user-profile-toggle { display: flex; align-items: center; gap: 12px; cursor: pointer; padding-left: 20px; border-left: 1px solid rgba(255,255,255,0.1); }
        .user-meta { display: flex; flex-direction: column; text-align: right; line-height: 1.1; }
        .u-name { color: #ffffff; font-size: 13px; font-weight: 700; }
        .u-role { color: #64748b; font-size: 11px; }
        .u-avatar { width: 38px; height: 38px; border-radius: 50%; border: 1px solid #334155; object-fit: cover; }

        /* Dropdown Menu */
        .user-dropdown-menu { background-color: #1e293b !important; border: 1px solid rgba(255,255,255,0.1) !important; border-radius: 8px !important; margin-top: 15px !important; box-shadow: 0 10px 25px rgba(0,0,0,0.5) !important; }
        .user-dropdown-menu .dropdown-item { color: #e2e8f0 !important; padding: 10px 20px !important; font-size: 14px; }
        .user-dropdown-menu .dropdown-item:hover { background-color: #334155 !important; color: #ffffff !important; }

        /* Notification Dropdown */
        .notification-dropdown {
            width: 300px;
            background-color: #1e293b !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 8px !important;
            margin-top: 15px !important;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5) !important;
            padding: 0;
        }
        .notification-dropdown .dropdown-item {
            color: #e2e8f0 !important;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 12px 15px !important;
        }
        .notification-dropdown .dropdown-item:hover {
            background-color: #334155 !important;
        }
        .notification-dropdown .dropdown-item:last-child {
            border-bottom: none;
        }
        .notification-header {
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .notification-header-title { color: #ffffff; font-weight: 600; }
        .notification-header-link { color: #3b82f6; font-size: 12px; }
        .notification-body { max-height: 300px; overflow-y: auto; }
        .notification-footer {
            padding: 12px;
            border-top: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }
        .notification-footer a { color: #3b82f6; font-size: 13px; }

        /* Notification Item Styles */
        .notif-item { display: flex; gap: 12px; }
        .notif-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .notif-icon.danger { background: rgba(239, 68, 68, 0.2); }
        .notif-icon.danger i { color: #ef4444; }
        .notif-icon.success { background: rgba(34, 197, 94, 0.2); }
        .notif-icon.success i { color: #22c55e; }
        .notif-icon.warning { background: rgba(245, 158, 11, 0.2); }
        .notif-icon.warning i { color: #f59e0b; }
        .notif-icon.info { background: rgba(59, 130, 246, 0.2); }
        .notif-icon.info i { color: #3b82f6; }
        .notif-title { color: #ffffff; font-size: 13px; font-weight: 500; }
        .notif-desc { color: #64748b; font-size: 11px; }
        .notif-time { color: #475569; font-size: 10px; margin-top: 4px; }

        /* Sidebar & Content */
        .main-sidebar {
            padding-top: 75px !important;
            z-index: 1030 !important;
            background-color: #0c1425 !important; /* Màu tối sâu */
        }

        /* Căn chỉnh lại List Menu */
        .nav-sidebar {
            padding: 0 10px !important;
        }

            .nav-sidebar .nav-item {
                margin-bottom: 8px !important;
            }

            /* Style cơ bản cho các Link menu */
            .nav-sidebar .nav-link {
                color: #94a3b8 !important;
                border-radius: 10px !important; /* Bo góc item */
                padding: 12px 15px !important;
                transition: all 0.3s ease;
                border: none !important;
            }

                /* HOVER: Lớp phủ nhẹ */
                .nav-sidebar .nav-link:hover {
                    background-color: rgba(255, 255, 255, 0.05) !important;
                    color: #ffffff !important;
                }

            /* ACTIVE PART: Khớp hoàn toàn ảnh 2 */
            .nav-sidebar .nav-item .nav-link.active {
                background: linear-gradient(90deg, rgba(30, 41, 59, 0.9) 0%, rgba(15, 23, 42, 0.3) 100%) !important;
                color: #ffffff !important;
                position: relative;
                box-shadow: none !important;
            }

                /* Vạch xanh Cyan bên trái cho phần Active */
                .nav-sidebar .nav-item .nav-link.active::before {
                    content: "";
                    position: absolute;
                    left: 0;
                    top: 15%;
                    height: 70%;
                    width: 4px;
                    background-color: #00e5ff; /* Màu Cyan đặc trưng */
                    border-radius: 0 4px 4px 0;
                    box-shadow: 0 0 10px rgba(0, 229, 255, 0.6);
                }

            /* Icon Active */
            .nav-sidebar .nav-link.active i {
                color: #00e5ff !important;
                filter: drop-shadow(0 0 5px rgba(0, 229, 255, 0.4));
            }

        /* Sidebar Footer Text */
        .sidebar-brand-footer {
            position: absolute;
            bottom: 30px;
            width: 100%;
            text-align: center;
            left: 0;
        }

            .sidebar-brand-footer span {
                color: #475569;
                font-size: 12px;
                letter-spacing: 1px;
                font-weight: 500;
            }

        /* Sửa lỗi hiển thị Dropdown và các thành phần khác của AdminLTE */
        .content-wrapper {
            background-color: #0a0a0a !important;
        }

        .nav-sidebar .nav-link p {
            margin-left: 10px;
        }

        @@keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
            70% { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
            100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
        }
    </style>

</head>
    @RenderSection("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

        <nav class="main-header navbar navbar-expand navbar-dark">
            <div class="header-left-group">
                <div class="brand-wrapper">
                    <img src="~/path/to/logo_afchem.png" style="height: 35px;" alt="Logo">
                    <div class="brand-text-content">
                        <span class="main-title">AFCHEM SYSTEM</span>
                        <span class="sub-title">SCADA MONITORING</span>
                    </div>
                </div>
            </div>

            <div class="header-right-group">
                <div class="plc-status-card d-none d-lg-flex">
                    <div class="dot-online"></div>
                    <div class="status-indicator">
                        <span class="status-label">PLC Status</span>
                        <span class="status-text">Online</span>
                    </div>
                </div>

                <div class="clock-wrapper d-none d-md-flex">
                    <i class="far fa-clock clock-icon"></i>
                    <div class="clock-data">
                        <span id="txtTime" class="clock-time">04:50:26 PM</span>
                        <span id="txtDate" class="clock-date">28/10/2023</span>
                    </div>
                </div>

                <div class="notification-btn" data-toggle="dropdown">
                    <i class="far fa-bell"></i>
                    <span class="badge-count">4</span>
                </div>
                <div class="dropdown-menu dropdown-menu-right notification-dropdown">
                    <div class="notification-header">
                        <span class="notification-header-title">Thông báo</span>
                        <a href="#" class="notification-header-link">Đánh dấu đã đọc</a>
                    </div>
                    <div class="notification-body">
                        <a href="#" class="dropdown-item">
                            <div class="notif-item">
                                <div class="notif-icon danger"><i class="fas fa-exclamation-triangle"></i></div>
                                <div>
                                    <div class="notif-title">Cảnh báo nhiệt độ cao</div>
                                    <div class="notif-desc">Inverter 3 vượt ngưỡng 65°C</div>
                                    <div class="notif-time">2 phút trước</div>
                                </div>
                            </div>
                        </a>
                        <a href="#" class="dropdown-item">
                            <div class="notif-item">
                                <div class="notif-icon success"><i class="fas fa-check-circle"></i></div>
                                <div>
                                    <div class="notif-title">Hệ thống hoạt động</div>
                                    <div class="notif-desc">Tất cả inverter kết nối thành công</div>
                                    <div class="notif-time">15 phút trước</div>
                                </div>
                            </div>
                        </a>
                        <a href="#" class="dropdown-item">
                            <div class="notif-item">
                                <div class="notif-icon warning"><i class="fas fa-bolt"></i></div>
                                <div>
                                    <div class="notif-title">Biến thiên công suất</div>
                                    <div class="notif-desc">Công suất giảm 20% - Inverter 5</div>
                                    <div class="notif-time">1 giờ trước</div>
                                </div>
                            </div>
                        </a>
                        <a href="#" class="dropdown-item">
                            <div class="notif-item">
                                <div class="notif-icon info"><i class="fas fa-info-circle"></i></div>
                                <div>
                                    <div class="notif-title">Cập nhật hệ thống</div>
                                    <div class="notif-desc">Phiên bản mới 2.5.0 đã sẵn sàng</div>
                                    <div class="notif-time">3 giờ trước</div>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="notification-footer">
                        <a href="#">Xem tất cả thông báo</a>
                    </div>
                </div>

                <div class="dropdown">
                    <div class="user-profile-toggle" data-toggle="dropdown">
                        <div class="user-meta d-none d-sm-flex">
                            <span class="u-name">Admin</span>
                            <span class="u-role">Administrator</span>
                        </div>
                        <img src="~/AdminLTE-master/dist/img/user2-160x160.jpg" class="u-avatar" alt="User">
                        <i class="fas fa-angle-down" style="color: #64748b; font-size: 11px;"></i>
                    </div>
                    <div class="dropdown-menu dropdown-menu-right user-dropdown-menu">
                        <a class="dropdown-item" href="#"><i class="fas fa-user-circle mr-2"></i> Thông tin cá nhân</a>
                        <div class="dropdown-divider" style="border-top: 1px solid rgba(255,255,255,0.05);"></div>
                        <a class="dropdown-item" href="@Url.Action("Logout", "Home")" style="color: #ef4444 !important;">
                            <i class="fas fa-sign-out-alt mr-2"></i> Đăng xuất
                        </a>
                    </div>
                </div>
            </div>
        </nav>

        <aside class="main-sidebar">
            <div class="sidebar">
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

                        <li class="nav-item">
                            <a href="~/Home/Overview" class="nav-link @(ViewBag.ButtonHome ?? "active")">
                                <i class="nav-icon fas fa-th-large"></i>
                                <p>Tổng quan</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="~/Home/Alarm" class="nav-link">
                                <i class="nav-icon fas fa-exclamation-triangle"></i>
                                <p>Cảnh báo</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="~/Home/Event" class="nav-link">
                                <i class="nav-icon fas fa-calendar"></i>
                                <p>Sự kiện</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="nav-icon fas fa-file-alt"></i>
                                <p>Báo cáo</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="~/Home/UserSetting" class="nav-link">
                                <i class="nav-icon fas fa-cog"></i>
                                <p>Cài đặt hệ thống</p>
                            </a>
                        </li>
                    </ul>
                </nav>

                <div class="sidebar-brand-footer">
                    <span>© 2026 HAPOSOFT</span>
                </div>
            </div>
        </aside>

        <div class="content-wrapper">
            @RenderBody()
        </div>
    </div>
    <!-- ./wrapper -->
    <!-- jQuery -->
    <script src="~/AdminLTE-master/plugins/jquery/jquery.min.js"></script>
    <!-- jQuery UI 1.11.4 -->
    <script src="~/AdminLTE-master/plugins/jquery-ui/jquery-ui.min.js"></script>
    <!-- Resolve conflict in jQuery UI tooltip with Bootstrap tooltip -->
    <script>$.widget.bridge('uibutton', $.ui.button)</script>
    <!-- Bootstrap 4 -->
    <script src="~/AdminLTE-master/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- ChartJS -->
    <script src="~/AdminLTE-master/plugins/chart.js/Chart.min.js"></script>
    <!-- Sparkline -->
    <script src="~/AdminLTE-master/plugins/sparklines/sparkline.js"></script>
    <!-- JQVMap -->
    <script src="~/AdminLTE-master/plugins/jqvmap/jquery.vmap.min.js"></script>
    <script src="~/AdminLTE-master/plugins/jqvmap/maps/jquery.vmap.usa.js"></script>
    <!-- jQuery Knob Chart -->
    <script src="~/AdminLTE-master/plugins/jquery-knob/jquery.knob.min.js"></script>
    <!-- daterangepicker -->
    <script src="~/AdminLTE-master/plugins/moment/moment.min.js"></script>
    <script src="~/AdminLTE-master/plugins/daterangepicker/daterangepicker.js"></script>
    <!-- Tempusdominus Bootstrap 4 -->
    <script src="~/AdminLTE-master/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
    <!-- Summernote -->
    <script src="~/AdminLTE-master/plugins/summernote/summernote-bs4.min.js"></script>
    <!-- overlayScrollbars -->
    @*<script src="~/AdminLTE-master/plugins/overlayScrollbars/js/jquery.overlayScrollbars.min.js"></script>*@
    <!-- AdminLTE App -->
    <script src="~/AdminLTE-master/dist/js/adminlte.js"></script>
    <!-- AdminLTE for demo purposes -->
    @*<script src="~/AdminLTE-master/dist/js/demo.js"></script>*@
    <!-- AdminLTE dashboard demo (This is only for demo purposes) -->
    <script src="~/AdminLTE-master/dist/js/pages/dashboard.js"></script>
    @*<script src="~/JavaScript/Common/Count.js"></script>*@
    <script>
        // Update Clock function
        function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true });
            const dateStr = now.toLocaleDateString('en-GB'); // dd/mm/yyyy
            document.getElementById('txtTime').innerText = timeStr;
            document.getElementById('txtDate').innerText = dateStr;
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
    @RenderSection("Scripts", false/*required*/)
</body>
</html>
